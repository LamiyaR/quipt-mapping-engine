          <Value>Cellular Band</Value>
        </CatalogTemplateRequest.Property>
        <CatalogTemplateRequest.Property>
          <Key>Value</Key>
          <Value>&lt;xsl:value-of select="q:Catalog/q:Attributes/q:Attribute[q:Code='CELLULARNETWORK']/q:Value/a:string[1]" /&gt;</Value>
        </CatalogTemplateRequest.Property>
      </Properties>
      <Type>Default</Type>
    </CatalogTemplateRequest.Attribute>
  </Attributes>
  <Global>
    <CatalogTemplateRequest.Property>
      <Key>CategoryId</Key>
      <Value>9355</Value>
